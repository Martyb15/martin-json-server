// ─── Prisma Schema for martinbarrios.com ───
// Maps directly from the existing db.json structure
// to a normalized PostgreSQL database.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── PROJECTS ───
model Project {
  id          Int       @id @default(autoincrement())
  name        String
  image       String
  techStack   String[]  // Postgres native array — no join table needed
  featured    Boolean   @default(false)
  description String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  comments    Comment[]

  @@map("projects")
}

// ─── COMMENTS ───
model Comment {
  id        Int      @id @default(autoincrement())
  projectId Int
  rating    Int      @db.SmallInt
  text      String
  author    String
  date      DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("comments")
}

// ─── SKILLS ───
model Skill {
  id          Int     @id @default(autoincrement())
  name        String
  image       String
  featured    Boolean @default(false)
  description String

  @@map("skills")
}

// ─── CERTIFICATIONS ───
model Certification {
  id          Int     @id @default(autoincrement())
  name        String
  image       String
  featured    Boolean @default(false)
  description String

  @@map("certifications")
}

// ─── CONTACT FORM FEEDBACK ───
model Feedback {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  phoneNum    String?
  email       String
  agree       Boolean  @default(false)
  contactType String
  feedback    String
  createdAt   DateTime @default(now())

  @@map("feedback")
}
